# App
PROJECT_NAME="AnimateAI"
ENVIRONMENT="development"
DEBUG=True

# Security (Change these in production)
SECRET_KEY="super_secret_key_change_me"
REFRESH_SECRET_KEY="super_secret_refresh_key_change_me"

# Database (Used by docker-compose)
POSTGRES_SERVER="db"
POSTGRES_USER="animateai"
POSTGRES_PASSWORD="password"
POSTGRES_DB="animateaidb"
POSTGRES_PORT=5432

# Redis
REDIS_HOST="redis"
REDIS_PORT=6379

# Storage
STORAGE_BACKEND="local"

# AI Core
GROQ_API_KEY="your_groq_api_key_here"

# Third-Party Media Providers (Optional but required for Phase 8)
FAL_API_KEY="your_fal_ai_key_here"
ELEVENLABS_API_KEY="your_elevenlabs_key_here"
